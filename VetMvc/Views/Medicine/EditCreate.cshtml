@model VetMvc.Models.MedicineModel
@{
    bool isEdit = Model != null && Model.MedicineId != 0;
    ViewData["Title"] = isEdit ? "İlaç Düzenle" : "İlaç Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-banner">
    <div>
        <h1><i class="fa-solid fa-pills"></i> @(isEdit ? "İlaç Düzenle" : "Yeni İlaç Ekle")</h1>
        <p>@(isEdit? Model.MedName: "Yeni kayıt oluştur")</p>
    </div>
    <div class="banner-icon">
        <i class="fa-solid fa-pills"></i>
    </div>
</div>

<div class="form-card">
    <form method="post" action="/Medicine/EditCreate">
        <input type="hidden" name="MedicineId" value="@(isEdit? Model.MedicineId: 0)" />

        <div class="form-group">
            <label>İlaç Adı</label>
            <input type="text" name="MedName" value="@Model?.MedName" placeholder="Amoksisilin..." />
        </div>
        <div class="form-group">
            <label>İlaç Türü</label>
            <select name="MedicineType">
                <option value="">-- Tür Seçin --</option>
                @foreach (var type in new[] { "Krem", "Jel", "Enjeksiyon", "Hap", "Efervesan Tablet", "Şaşe", "Damla", "Sprey" })
                {
                    <option value="@type" selected="@(isEdit && Model.MedicineType == type ? "selected" : null)">
                        @type
                    </option>
                }
            </select>
        </div>
        <div class="form-group">
            <label>Kullanım Açıklaması</label>
            <input type="text" name="UsageDescription" value="@Model?.UsageDescription" placeholder="Günde 2 kez, yemekle birlikte..." />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-save">
                <i class="fa-solid fa-floppy-disk"></i> Kaydet
            </button>
            <a href="/Medicine" class="btn btn-cancel">İptal</a>
        </div>
    </form>
</div>
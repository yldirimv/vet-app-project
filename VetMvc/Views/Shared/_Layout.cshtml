<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pati Veteriner - @ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --red: #C0392B;
            --blue: #1A3C6E;
            --blue-mid: #2456A4;
            --blue-light: #EAF0FB;
            --white: #FFFFFF;
            --gray-bg: #F5F7FA;
            --gray-border: #DDE3ED;
            --text: #1a1a2e;
            --text-soft: #5a6480;
        }

        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: var(--gray-bg);
            color: var(--text);
            min-height: 100vh;
        }

        nav {
            background: var(--blue);
            padding: 0 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 2px 8px rgba(0,0,0,0.18);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-left {
            display: flex;
            align-items: center;
            gap: 2rem;
        }

        .nav-brand {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            text-decoration: none;
            padding: 1rem 0;
        }

            .nav-brand img {
                width: 36px;
                height: 36px;
                object-fit: contain;
            }

            .nav-brand span {
                font-size: 1.2rem;
                font-weight: 700;
                color: var(--white);
            }

                .nav-brand span em {
                    color: #EF9A9A;
                    font-style: normal;
                }

        .nav-links {
            display: flex;
            gap: 0.25rem;
        }

            .nav-links a {
                color: rgba(255,255,255,0.78);
                text-decoration: none;
                padding: 0.55rem 1rem;
                border-radius: 6px;
                font-size: 0.92rem;
                font-weight: 500;
                transition: background 0.15s, color 0.15s;
                display: flex;
                align-items: center;
                gap: 0.4rem;
            }

                .nav-links a:hover,
                .nav-links a.active {
                    background: rgba(255,255,255,0.13);
                    color: var(--white);
                }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .nav-user {
            color: rgba(255,255,255,0.78);
            font-size: 0.88rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .btn-logout {
            background: rgba(192,57,43,0.8);
            color: white;
            border: none;
            padding: 0.45rem 1rem;
            border-radius: 6px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            transition: background 0.15s;
        }

            .btn-logout:hover {
                background: var(--red);
            }

        .page-wrapper {
            max-width: 1100px;
            margin: 2.5rem auto;
            padding: 0 1.5rem;
        }

        .page-banner {
            background: linear-gradient(135deg, #1A3C6E 0%, #2456A4 100%);
            border-radius: 12px;
            padding: 1.5rem 2rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            color: white;
        }

            .page-banner h1 {
                font-size: 1.4rem;
                font-weight: 700;
            }

            .page-banner p {
                font-size: 0.85rem;
                opacity: 0.8;
                margin-top: 0.2rem;
            }

            .page-banner .banner-icon {
                font-size: 2.5rem;
                opacity: 0.25;
            }

        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.52rem 1.1rem;
            border-radius: 7px;
            font-size: 0.88rem;
            font-weight: 600;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: opacity 0.15s;
        }

            .btn:hover {
                opacity: 0.85;
            }

        .btn-primary {
            background: var(--blue-mid);
            color: var(--white);
        }

        .btn-edit {
            background: var(--blue-light);
            color: var(--blue-mid);
        }

        .btn-delete {
            background: #FDECEA;
            color: var(--red);
        }

        .btn-save {
            background: var(--blue-mid);
            color: var(--white);
            padding: 0.6rem 1.6rem;
        }

        .btn-cancel {
            background: var(--gray-border);
            color: var(--text-soft);
        }

        .card {
            background: var(--white);
            border-radius: 12px;
            border: 1px solid var(--gray-border);
            overflow: hidden;
            box-shadow: 0 1px 4px rgba(26,60,110,0.06);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }

        thead tr {
            background: var(--blue);
            color: var(--white);
        }

        thead th {
            padding: 0.85rem 1rem;
            text-align: left;
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        tbody tr {
            border-bottom: 1px solid var(--gray-border);
            transition: background 0.1s;
        }

            tbody tr:last-child {
                border-bottom: none;
            }

            tbody tr:hover {
                background: var(--blue-light);
            }

        tbody td {
            padding: 0.85rem 1rem;
        }

        .actions {
            display: flex;
            gap: 0.4rem;
        }

        .badge {
            display: inline-block;
            padding: 0.2rem 0.6rem;
            border-radius: 20px;
            font-size: 0.78rem;
            font-weight: 600;
            background: var(--blue-light);
            color: var(--blue-mid);
        }

        .form-card {
            background: var(--white);
            border-radius: 12px;
            border: 1px solid var(--gray-border);
            padding: 2rem;
            max-width: 560px;
            box-shadow: 0 1px 4px rgba(26,60,110,0.06);
        }

        .form-group {
            margin-bottom: 1.2rem;
        }

            .form-group label {
                display: block;
                font-size: 0.82rem;
                font-weight: 600;
                color: var(--text-soft);
                margin-bottom: 0.4rem;
                text-transform: uppercase;
                letter-spacing: 0.3px;
            }

            .form-group input,
            .form-group select {
                width: 100%;
                padding: 0.6rem 0.85rem;
                border: 1.5px solid var(--gray-border);
                border-radius: 7px;
                font-size: 0.93rem;
                color: var(--text);
                background: var(--white);
                outline: none;
                transition: border-color 0.15s;
            }

                .form-group input:focus,
                .form-group select:focus {
                    border-color: var(--blue-mid);
                }

        .form-actions {
            display: flex;
            gap: 0.75rem;
            margin-top: 1.5rem;
        }

        .search-bar {
            display: flex;
            gap: 0.75rem;
            margin-bottom: 1.2rem;
            flex-wrap: wrap;
        }

        .search-input-wrap {
            position: relative;
            flex: 1;
            min-width: 200px;
        }

            .search-input-wrap i {
                position: absolute;
                left: 0.85rem;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-soft);
                font-size: 0.85rem;
            }

            .search-input-wrap input {
                width: 100%;
                padding: 0.6rem 0.85rem 0.6rem 2.4rem;
                border: 1.5px solid var(--gray-border);
                border-radius: 8px;
                font-size: 0.9rem;
                outline: none;
                background: white;
                transition: border-color 0.15s;
            }

                .search-input-wrap input:focus {
                    border-color: var(--blue-mid);
                }

        .btn-search {
            background: var(--blue-mid);
            color: white;
            border: none;
            padding: 0.6rem 1.2rem;
            border-radius: 8px;
            font-size: 0.88rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            transition: opacity 0.15s;
        }

            .btn-search:hover {
                opacity: 0.85;
            }

        .empty {
            text-align: center;
            padding: 3rem;
            color: var(--text-soft);
        }

            .empty .icon {
                font-size: 2.5rem;
                margin-bottom: 0.5rem;
            }
    </style>
</head>
<body>
    <nav>
        <div class="nav-left">
            <a class="nav-brand" href="/Home/Index">
                <img src="~/images/logo.png" alt="logo" onerror="this.style.display='none'" />
                <span> Pati <em>Veteriner</em></span>
            </a>
            <div class="nav-links">
                <a href="/Employee/Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Employee" ? "active" : "")">
                    <i class="fa-solid fa-user-doctor"></i> Çalışanlar
                </a>
                <a href="/Pet/Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Pet" ? "active" : "")">
                    <i class="fa-solid fa-paw"></i> Hastalar
                </a>
                <a href="/Medicine/Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Medicine" ? "active" : "")">
                    <i class="fa-solid fa-pills"></i> İlaçlar
                </a>
                <a href="/Treatment/Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Treatment" ? "active" : "")">
                    <i class="fa-solid fa-stethoscope"></i> Tedaviler
                </a>
            </div>
        </div>
        <div class="nav-right">
            <div class="nav-user">
                <i class="fa-solid fa-circle-user"></i>
                @Context.Session.GetString("NameSurname")
            </div>
            <a href="/Employee/Logout" class="btn-logout">
                <i class="fa-solid fa-right-from-bracket"></i> Çıkış
            </a>
        </div>
    </nav>

    <div class="page-wrapper">
        @RenderBody()
    </div>
</body>
</html>